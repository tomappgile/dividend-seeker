{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'Build date: 2026-03-01' && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn web.app:app --bind 0.0.0.0:$PORT --timeout 120",
    "restartPolicyType": "ON_FAILURE"
  }
}
